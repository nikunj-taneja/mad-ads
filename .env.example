# Copy this file to .env. Never commit .env.
#
# Local tools need no credentials. Meta tools use the variables below and load
# the repository .env automatically. Keep unused values blank.

# Meta Marketing API (optional; read-only audit and paused image-hash upload)
# From Meta Business Settings / the Graph API token flow. Do not use a personal
# short-lived token for unattended automation.
META_ACCESS_TOKEN=
# Numeric ad account ID, conventionally written act_1234567890.
META_AD_ACCOUNT_ID=
# Pin integrations to a tested Graph API version, for example vXX.X.
# Choose the version when implementing/testing the integration; do not guess.
META_API_VERSION=
# Page and Instagram identities are required for many ad creative operations.
META_PAGE_ID=
META_INSTAGRAM_ACTOR_ID=

# Shopify Admin API (optional; commerce integration is not currently shipped)
# Store hostname only, for example example-store.myshopify.com (no https://).
SHOPIFY_STORE_DOMAIN=
# A custom app Admin API access token with the minimum required scopes.
SHOPIFY_ACCESS_TOKEN=
